{
  "contract_version": "1.0.0",
  "project": "VentureIntelligence - The VC Brain",
  "source_of_truth": "steps.md",
  "description": "Shared contract for the frontend, backend, and bounded AI lane. Public product routes are owned by the backend; the AI service exposes only fixed internal stages for the backend to call or import.",
  "principles": [
    "The public product API is /api. Frontend mocks must use the canonical bodies in data/fixtures.",
    "The backend owns SQLite Memory, ingestion and identity resolution, Founder Score persistence, endpoint orchestration, the human gate, audit and metrics, and the deterministic Decision Brief.",
    "The AI lane owns fixed extractor, query, screen, diligence, memo, adversary, and batched adversary-verification stages. It never owns a human decision.",
    "There is no debate loop, no agent swarm, and no LLM winner declaration.",
    "Every factual AI output is constrained by supplied Claims and Memory Signals. Missing evidence is uncertainty, not a negative fact.",
    "All timestamps are ISO 8601 UTC strings. Arrays are never null. Status is only the human gate status."
  ],
  "models": {
    "extract": "gpt-5.6-luna",
    "query": "gpt-5.6-luna",
    "screen": "gpt-5.6-terra",
    "diligence": "gpt-5.6-terra",
    "memo": "gpt-5.6-terra",
    "adversary": "gpt-5.6-terra",
    "verify_adversary": "gpt-5.6-terra"
  },
  "enums": {
    "origin": ["github", "hn", "inbound", "synthetic"],
    "claim_type": ["traction", "team", "market", "product"],
    "human_status": ["open", "approved", "rejected"],
    "trend": ["up", "flat", "down"],
    "market_rating": ["bullish", "neutral", "bear"],
    "idea_verdict": ["survives", "pivot", "fails"],
    "claim_verdict": ["supported", "contradicted", "unverifiable"],
    "trust": ["high", "med", "low"],
    "risk_appetite": ["low", "medium", "high"],
    "attack_label": ["evidence-backed", "speculation"],
    "attack_verification": ["verified", "unverified", "n/a"],
    "contested_severity": ["red", "yellow", "dim"]
  },
  "schemas": {
    "EmptyObject": {"type": "object", "additionalProperties": false},
    "OkResponse": {
      "type": "object",
      "required": ["ok"],
      "properties": {"ok": {"type": "boolean", "const": true}}
    },
    "Signal": {
      "type": "object",
      "required": ["signal_id", "ts", "source", "text", "url"],
      "properties": {
        "signal_id": {"type": "string"},
        "ts": {"type": "string", "format": "date-time"},
        "source": {"type": "string"},
        "text": {"type": "string"},
        "url": {"type": ["string", "null"], "format": "uri"}
      }
    },
    "Claim": {
      "type": "object",
      "required": ["claim_id", "type", "text", "source_span"],
      "properties": {
        "claim_id": {"type": "string"},
        "type": {"enum_ref": "claim_type"},
        "text": {"type": "string"},
        "source_span": {"type": ["string", "null"]}
      }
    },
    "QueryFilter": {
      "type": "object",
      "required": ["technical_founder", "sectors", "geos", "shipped_within_days", "prior_vc"],
      "properties": {
        "technical_founder": {"type": ["boolean", "null"]},
        "sectors": {"type": "array", "items": {"type": "string"}},
        "geos": {"type": "array", "items": {"type": "string"}},
        "shipped_within_days": {"type": ["integer", "null"], "minimum": 0},
        "prior_vc": {"type": ["boolean", "null"]}
      }
    },
    "Thesis": {
      "type": "object",
      "required": ["sectors", "stage", "geo", "check_size", "risk_appetite"],
      "properties": {
        "sectors": {"type": "array", "items": {"type": "string"}},
        "stage": {"type": "string"},
        "geo": {"type": "array", "items": {"type": "string"}},
        "check_size": {"type": "integer", "const": 100000},
        "risk_appetite": {"enum_ref": "risk_appetite"}
      }
    },
    "Profile": {
      "type": "object",
      "required": ["founder_id", "name", "headline", "location", "origin", "bio"],
      "properties": {
        "founder_id": {"type": "string"},
        "name": {"type": "string"},
        "headline": {"type": ["string", "null"]},
        "location": {"type": ["string", "null"]},
        "origin": {"enum_ref": "origin"},
        "bio": {"type": ["string", "null"]}
      }
    },
    "FounderScore": {
      "type": "object",
      "required": ["score", "band", "trend"],
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 100},
        "band": {"type": "integer", "minimum": 5, "maximum": 30},
        "trend": {"enum_ref": "trend"}
      }
    },
    "Axes": {
      "type": "object",
      "required": ["founder", "market", "idea_vs_market"],
      "properties": {
        "founder": {
          "type": "object",
          "required": ["score", "trend", "rationale"],
          "properties": {
            "score": {"type": "number", "minimum": 0, "maximum": 10},
            "trend": {"enum_ref": "trend"},
            "rationale": {"type": "string"}
          }
        },
        "market": {
          "type": "object",
          "required": ["rating", "rationale"],
          "properties": {
            "rating": {"enum_ref": "market_rating"},
            "rationale": {"type": "string"}
          }
        },
        "idea_vs_market": {
          "type": "object",
          "required": ["verdict", "rationale"],
          "properties": {
            "verdict": {"enum_ref": "idea_verdict"},
            "rationale": {"type": "string"}
          }
        }
      }
    },
    "DiligenceClaim": {
      "type": "object",
      "required": ["claim_id", "verdict", "trust", "evidence", "note"],
      "properties": {
        "claim_id": {"type": "string"},
        "verdict": {"enum_ref": "claim_verdict"},
        "trust": {"enum_ref": "trust"},
        "evidence": {"type": "array", "items": {"type": "string"}},
        "note": {"type": "string"}
      }
    },
    "Diligence": {
      "type": "object",
      "required": ["claims", "gaps"],
      "properties": {
        "claims": {"type": "array", "items": {"$ref": "#/schemas/DiligenceClaim"}},
        "gaps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "Recommendation": {
      "type": "object",
      "required": ["invest", "amount", "rationale", "based_on"],
      "properties": {
        "invest": {"type": "boolean"},
        "amount": {"type": "integer", "const": 100000},
        "rationale": {"type": "string"},
        "based_on": {"type": "array", "items": {"type": "string"}}
      }
    },
    "Memo": {
      "type": "object",
      "required": ["memo_id", "sections", "recommendation"],
      "properties": {
        "memo_id": {"type": "string"},
        "sections": {
          "type": "object",
          "required": ["snapshot", "hypotheses", "swot", "problem_product", "traction_kpis"],
          "properties": {
            "snapshot": {"type": "string"},
            "hypotheses": {"type": "string"},
            "swot": {"type": "string"},
            "problem_product": {"type": "string"},
            "traction_kpis": {"type": "string"}
          }
        },
        "recommendation": {"$ref": "#/schemas/Recommendation"}
      }
    },
    "AdversarialObjection": {
      "type": "object",
      "required": ["text", "targets", "evidence", "label", "verification"],
      "properties": {
        "text": {"type": "string"},
        "targets": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": ["array", "null"], "items": {"type": "string"}},
        "label": {"enum_ref": "attack_label"},
        "verification": {"enum_ref": "attack_verification"}
      }
    },
    "Adversarial": {
      "type": "object",
      "required": ["persona", "objections"],
      "properties": {
        "persona": {"type": "string"},
        "objections": {"type": "array", "items": {"$ref": "#/schemas/AdversarialObjection"}}
      }
    },
    "DecisionBrief": {
      "type": "object",
      "required": ["summary", "contested", "stats"],
      "properties": {
        "summary": {"type": "string"},
        "contested": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_id", "objection_i", "severity"],
            "properties": {
              "claim_id": {"type": "string"},
              "objection_i": {"type": "integer", "minimum": 0},
              "severity": {"enum_ref": "contested_severity"}
            }
          }
        },
        "stats": {
          "type": "object",
          "required": ["claims", "contested", "verified_attacks"],
          "properties": {
            "claims": {"type": "integer", "minimum": 0},
            "contested": {"type": "integer", "minimum": 0},
            "verified_attacks": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "SetThesisRequest": {
      "type": "object",
      "required": ["thesis"],
      "properties": {"thesis": {"$ref": "#/schemas/Thesis"}}
    },
    "GetThesisResponse": {
      "type": "object",
      "required": ["thesis"],
      "properties": {"thesis": {"$ref": "#/schemas/Thesis"}}
    },
    "ScanRunResponse": {
      "type": "object",
      "required": ["new_founders", "new_signals", "cached"],
      "properties": {
        "new_founders": {"type": "integer", "minimum": 0},
        "new_signals": {"type": "integer", "minimum": 0},
        "cached": {"type": "boolean"}
      }
    },
    "DashboardFounder": {
      "type": "object",
      "required": ["founder_id", "name", "origin", "founder_score", "band", "trend", "top_signals", "has_open_app"],
      "properties": {
        "founder_id": {"type": "string"},
        "name": {"type": "string"},
        "origin": {"enum_ref": "origin"},
        "founder_score": {"type": "number", "minimum": 0, "maximum": 100},
        "band": {"type": "integer", "minimum": 5, "maximum": 30},
        "trend": {"enum_ref": "trend"},
        "top_signals": {"type": "array", "items": {"type": "string"}},
        "has_open_app": {"type": "boolean"}
      }
    },
    "QueryRequest": {
      "type": "object",
      "required": ["q"],
      "properties": {"q": {"type": "string"}}
    },
    "QueryResponse": {
      "type": "object",
      "required": ["filter", "results"],
      "properties": {
        "filter": {"$ref": "#/schemas/QueryFilter"},
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["founder_id", "why_matched"],
            "properties": {
              "founder_id": {"type": "string"},
              "why_matched": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "FounderResponse": {
      "type": "object",
      "required": ["profile", "signals", "score_history", "applications"],
      "properties": {
        "profile": {"$ref": "#/schemas/Profile"},
        "signals": {"type": "array", "items": {"$ref": "#/schemas/Signal"}},
        "score_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ts", "score", "band"],
            "properties": {
              "ts": {"type": "string", "format": "date-time"},
              "score": {"type": "number", "minimum": 0, "maximum": 100},
              "band": {"type": "integer", "minimum": 5, "maximum": 30}
            }
          }
        },
        "applications": {"type": "array", "items": {"type": "string"}}
      }
    },
    "ActivateResponse": {
      "type": "object",
      "required": ["outreach_draft"],
      "properties": {"outreach_draft": {"type": "string"}}
    },
    "CreateApplicationRequest": {
      "type": "object",
      "required": ["company_name", "deck_text"],
      "properties": {
        "company_name": {"type": "string"},
        "deck_text": {"type": "string"}
      }
    },
    "CreateApplicationResponse": {
      "type": "object",
      "required": ["application_id", "founder_id", "claims"],
      "properties": {
        "application_id": {"type": "string"},
        "founder_id": {"type": "string"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}}
      }
    },
    "ApplicationResponse": {
      "type": "object",
      "required": ["application_id", "founder_id", "company_name", "status", "claims", "axes", "diligence", "memo", "adversarial", "decision_brief", "evidence"],
      "properties": {
        "application_id": {"type": "string"},
        "founder_id": {"type": "string"},
        "company_name": {"type": "string"},
        "status": {"enum_ref": "human_status"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "axes": {"oneOf": [{"$ref": "#/schemas/Axes"}, {"type": "null"}]},
        "diligence": {"oneOf": [{"$ref": "#/schemas/Diligence"}, {"type": "null"}]},
        "memo": {"oneOf": [{"$ref": "#/schemas/Memo"}, {"type": "null"}]},
        "adversarial": {"oneOf": [{"$ref": "#/schemas/Adversarial"}, {"type": "null"}]},
        "decision_brief": {"oneOf": [{"$ref": "#/schemas/DecisionBrief"}, {"type": "null"}]},
        "evidence": {"type": "array", "items": {"$ref": "#/schemas/Signal"}}
      }
    },
    "ScreenResponse": {
      "type": "object",
      "required": ["axes"],
      "properties": {"axes": {"$ref": "#/schemas/Axes"}}
    },
    "AdversaryResponse": {
      "type": "object",
      "required": ["adversarial", "decision_brief"],
      "properties": {
        "adversarial": {"$ref": "#/schemas/Adversarial"},
        "decision_brief": {"$ref": "#/schemas/DecisionBrief"}
      }
    },
    "DecisionQueueItem": {
      "type": "object",
      "required": ["application_id", "company", "recommendation", "memo_id"],
      "properties": {
        "application_id": {"type": "string"},
        "company": {"type": "string"},
        "recommendation": {"$ref": "#/schemas/Recommendation"},
        "memo_id": {"type": "string"}
      }
    },
    "DecisionRequest": {
      "type": "object",
      "required": ["action", "approver"],
      "properties": {
        "action": {"enum": ["approve", "reject"]},
        "approver": {"type": "string"}
      }
    },
    "DecisionResponse": {
      "type": "object",
      "required": ["status", "audit_id"],
      "properties": {
        "status": {"enum": ["approved", "rejected"]},
        "audit_id": {"type": "string"}
      }
    },
    "AuditRecord": {
      "type": "object",
      "required": ["ts", "stage", "actor", "action", "detail"],
      "properties": {
        "ts": {"type": "string", "format": "date-time"},
        "stage": {"type": "string"},
        "actor": {"type": "string"},
        "action": {"type": "string"},
        "detail": {"type": "string"}
      }
    },
    "MetricsResponse": {
      "type": "object",
      "required": ["signal_to_decision_min", "funnel"],
      "properties": {
        "signal_to_decision_min": {"type": ["number", "null"]},
        "funnel": {
          "type": "object",
          "required": ["sourced", "screened", "diligenced", "decided"],
          "properties": {
            "sourced": {"type": "integer", "minimum": 0},
            "screened": {"type": "integer", "minimum": 0},
            "diligenced": {"type": "integer", "minimum": 0},
            "decided": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "ExtractRequest": {
      "type": "object",
      "required": ["company_name", "deck_text"],
      "properties": {
        "company_name": {"type": "string"},
        "deck_text": {"type": "string"}
      }
    },
    "ExtractResult": {
      "type": "object",
      "required": ["founder_name", "claims"],
      "properties": {
        "founder_name": {"type": "string"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}}
      }
    },
    "AIQueryRequest": {
      "type": "object",
      "required": ["q", "thesis"],
      "properties": {
        "q": {"type": "string"},
        "thesis": {"$ref": "#/schemas/Thesis"}
      }
    },
    "AIScreenRequest": {
      "type": "object",
      "required": ["company_name", "claims", "signals", "founder_score", "band", "trend", "thesis"],
      "properties": {
        "company_name": {"type": "string"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "signals": {"type": "array", "items": {"$ref": "#/schemas/Signal"}},
        "founder_score": {"type": "number", "minimum": 0, "maximum": 100},
        "band": {"type": "integer", "minimum": 5, "maximum": 30},
        "trend": {"enum_ref": "trend"},
        "thesis": {"$ref": "#/schemas/Thesis"}
      }
    },
    "AIDiligenceRequest": {
      "type": "object",
      "required": ["claims", "signals"],
      "properties": {
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "signals": {"type": "array", "items": {"$ref": "#/schemas/Signal"}}
      }
    },
    "AIMemoRequest": {
      "type": "object",
      "required": ["company_name", "claims", "diligence", "axes"],
      "properties": {
        "company_name": {"type": "string"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "diligence": {"$ref": "#/schemas/Diligence"},
        "axes": {"$ref": "#/schemas/Axes"}
      }
    },
    "AIAdversaryRequest": {
      "type": "object",
      "required": ["memo", "axes", "claims", "signals"],
      "properties": {
        "memo": {"$ref": "#/schemas/Memo"},
        "axes": {"$ref": "#/schemas/Axes"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "signals": {"type": "array", "items": {"$ref": "#/schemas/Signal"}}
      }
    },
    "AIVerifyAdversaryRequest": {
      "type": "object",
      "required": ["adversarial", "claims", "signals"],
      "properties": {
        "adversarial": {"$ref": "#/schemas/Adversarial"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "signals": {"type": "array", "items": {"$ref": "#/schemas/Signal"}}
      }
    },
    "AIApplicationRunRequest": {
      "type": "object",
      "required": ["company_name", "deck_text", "signals", "founder_score", "band", "trend", "thesis", "include_adversary"],
      "properties": {
        "company_name": {"type": "string"},
        "deck_text": {"type": "string"},
        "signals": {"type": "array", "items": {"$ref": "#/schemas/Signal"}},
        "founder_score": {"type": "number", "minimum": 0, "maximum": 100},
        "band": {"type": "integer", "minimum": 5, "maximum": 30},
        "trend": {"enum_ref": "trend"},
        "thesis": {"$ref": "#/schemas/Thesis"},
        "include_adversary": {"type": "boolean"}
      }
    },
    "AIApplicationRunResult": {
      "type": "object",
      "required": ["founder_name", "claims", "axes", "diligence", "memo", "adversarial", "trace"],
      "properties": {
        "founder_name": {"type": "string"},
        "claims": {"type": "array", "items": {"$ref": "#/schemas/Claim"}},
        "axes": {"$ref": "#/schemas/Axes"},
        "diligence": {"$ref": "#/schemas/Diligence"},
        "memo": {"$ref": "#/schemas/Memo"},
        "adversarial": {"oneOf": [{"$ref": "#/schemas/Adversarial"}, {"type": "null"}]},
        "trace": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "product_api": {
    "base_path": "/api",
    "owner": "backend",
    "endpoints": [
      {"method": "POST", "path": "/thesis", "request_schema": {"$ref": "#/schemas/SetThesisRequest"}, "response_schema": {"$ref": "#/schemas/OkResponse"}},
      {"method": "GET", "path": "/thesis", "response_schema": {"$ref": "#/schemas/GetThesisResponse"}},
      {"method": "POST", "path": "/scan/run", "request_schema": {"$ref": "#/schemas/EmptyObject"}, "response_schema": {"$ref": "#/schemas/ScanRunResponse"}},
      {"method": "GET", "path": "/dashboard", "response_schema": {"type": "array", "items": {"$ref": "#/schemas/DashboardFounder"}}},
      {"method": "POST", "path": "/query", "request_schema": {"$ref": "#/schemas/QueryRequest"}, "response_schema": {"$ref": "#/schemas/QueryResponse"}},
      {"method": "GET", "path": "/founders/{id}", "response_schema": {"$ref": "#/schemas/FounderResponse"}},
      {"method": "POST", "path": "/founders/{id}/activate", "request_schema": {"$ref": "#/schemas/EmptyObject"}, "response_schema": {"$ref": "#/schemas/ActivateResponse"}},
      {"method": "POST", "path": "/applications", "request_schema": {"$ref": "#/schemas/CreateApplicationRequest"}, "response_schema": {"$ref": "#/schemas/CreateApplicationResponse"}},
      {"method": "GET", "path": "/applications/{id}", "response_schema": {"$ref": "#/schemas/ApplicationResponse"}},
      {"method": "POST", "path": "/applications/{id}/screen", "request_schema": {"$ref": "#/schemas/EmptyObject"}, "response_schema": {"$ref": "#/schemas/ScreenResponse"}},
      {"method": "POST", "path": "/applications/{id}/diligence", "request_schema": {"$ref": "#/schemas/EmptyObject"}, "response_schema": {"$ref": "#/schemas/Diligence"}},
      {"method": "POST", "path": "/applications/{id}/memo", "request_schema": {"$ref": "#/schemas/EmptyObject"}, "response_schema": {"$ref": "#/schemas/Memo"}},
      {"method": "POST", "path": "/applications/{id}/adversary", "request_schema": {"$ref": "#/schemas/EmptyObject"}, "response_schema": {"$ref": "#/schemas/AdversaryResponse"}, "errors": [{"status": 409, "when": "memo is missing"}], "idempotent": true},
      {"method": "GET", "path": "/decisions/queue", "response_schema": {"type": "array", "items": {"$ref": "#/schemas/DecisionQueueItem"}}},
      {"method": "POST", "path": "/decisions/{id}/decide", "request_schema": {"$ref": "#/schemas/DecisionRequest"}, "response_schema": {"$ref": "#/schemas/DecisionResponse"}},
      {"method": "GET", "path": "/audit?founder_id=", "response_schema": {"type": "array", "items": {"$ref": "#/schemas/AuditRecord"}}},
      {"method": "GET", "path": "/metrics", "response_schema": {"$ref": "#/schemas/MetricsResponse"}}
    ]
  },
  "ai_service_api": {
    "base_path": "/v1/ai",
    "owner": "ai lane",
    "integration": "Backend may call these over HTTP or import the same named Python functions from ai_service.pipeline. They are internal contracts, never frontend routes.",
    "endpoints": [
      {"function": "extract_application", "method": "POST", "path": "/extract", "request_schema": {"$ref": "#/schemas/ExtractRequest"}, "response_schema": {"$ref": "#/schemas/ExtractResult"}, "model": "gpt-5.6-luna"},
      {"function": "parse_query", "method": "POST", "path": "/query", "request_schema": {"$ref": "#/schemas/AIQueryRequest"}, "response_schema": {"$ref": "#/schemas/QueryFilter"}, "model": "gpt-5.6-luna"},
      {"function": "screen_application", "method": "POST", "path": "/screen", "request_schema": {"$ref": "#/schemas/AIScreenRequest"}, "response_schema": {"$ref": "#/schemas/Axes"}, "model": "gpt-5.6-terra"},
      {"function": "diligence_claims", "method": "POST", "path": "/diligence", "request_schema": {"$ref": "#/schemas/AIDiligenceRequest"}, "response_schema": {"$ref": "#/schemas/Diligence"}, "model": "gpt-5.6-terra"},
      {"function": "write_memo", "method": "POST", "path": "/memo", "request_schema": {"$ref": "#/schemas/AIMemoRequest"}, "response_schema": {"$ref": "#/schemas/Memo"}, "model": "gpt-5.6-terra"},
      {"function": "write_adversary", "method": "POST", "path": "/adversary", "request_schema": {"$ref": "#/schemas/AIAdversaryRequest"}, "response_schema": {"$ref": "#/schemas/Adversarial"}, "model": "gpt-5.6-terra"},
      {"function": "verify_adversary", "method": "POST", "path": "/adversary/verify", "request_schema": {"$ref": "#/schemas/AIVerifyAdversaryRequest"}, "response_schema": {"$ref": "#/schemas/Adversarial"}, "model": "gpt-5.6-terra", "batch": true},
