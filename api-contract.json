{
  "contract_version": "0.2.0",
  "project": "the-vc-brain",
  "description": "Shared API contract for frontend, backend, and AI service collaboration.",
  "principles": [
    "All factual AI outputs must trace to Memory evidence records.",
    "The final investment decision is made by a human reviewer.",
    "The adversary is a one-pass devil's advocate, not a debate agent.",
    "Adversarial objections are verified by the same truth-gap Judge used for normal claim verification.",
    "The optional verdict brief summarizes verified attacks for readability but does not decide who won."
  ],
  "enums": {
    "job_status": [
      "queued",
      "running",
      "succeeded",
      "failed",
      "cancelled"
    ],
    "deal_status": [
      "draft",
      "researching",
      "screened",
      "memo_ready",
      "counter_case_ready",
      "review_ready",
      "approved",
      "rejected",
      "watchlist",
      "needs_more_research"
    ],
    "recommendation": [
      "approve",
      "reject",
      "watchlist",
      "needs_more_research"
    ],
    "screening_axis": [
      "founder",
      "market",
      "product",
      "traction",
      "business_model",
      "fundraising",
      "risk"
    ],
    "evidence_type": [
      "company",
      "founder",
      "market",
      "product",
      "traction",
      "competition",
      "business_model",
      "fundraising",
      "risk",
      "unknown"
    ],
    "confidence": [
      "low",
      "medium",
      "high"
    ],
    "freshness": [
      "current",
      "stale",
      "unknown"
    ],
    "objection_badge": [
      "verified",
      "unverified",
      "speculation"
    ],
    "brief_signal": [
      "memo_still_strong",
      "counter_case_serious",
      "needs_human_diligence"
    ],
    "decision_impact": [
      "none",
      "minor",
      "major",
      "blocking"
    ],
    "source_kind": [
      "company_site",
      "founder_profile",
      "news",
      "investor_page",
      "product_page",
      "review",
      "market_report",
      "regulatory",
      "social",
      "other"
    ]
  },
  "schemas": {
    "DealIntake": {
      "type": "object",
      "required": [
        "company_name"
      ],
      "properties": {
        "company_name": {
          "type": "string",
          "example": "Acme AI"
        },
        "company_url": {
          "type": "string",
          "format": "uri",
          "nullable": true,
          "example": "https://example.com"
        },
        "short_description": {
          "type": "string",
          "nullable": true
        },
        "founder_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deck_text": {
          "type": "string",
          "nullable": true
        },
        "submitted_by": {
          "type": "string",
          "nullable": true
        }
      }
    },
    "Deal": {
      "type": "object",
      "required": [
        "deal_id",
        "status",
        "intake",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "deal_id": {
          "type": "string",
          "example": "deal_01JABC123"
        },
        "status": {
          "$ref": "#/enums/deal_status"
        },
        "intake": {
          "$ref": "#/schemas/DealIntake"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Job": {
      "type": "object",
      "required": [
        "job_id",
        "deal_id",
        "job_type",
        "status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "job_id": {
          "type": "string",
          "example": "job_01JABC456"
        },
        "deal_id": {
          "type": "string"
        },
        "job_type": {
          "type": "string",
          "example": "research"
        },
        "status": {
          "$ref": "#/enums/job_status"
        },
        "progress_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "message": {
          "type": "string",
          "nullable": true
        },
        "error": {
          "type": "string",
          "nullable": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Source": {
      "type": "object",
      "required": [
        "source_id",
        "url",
        "title",
        "kind",
        "fetched_at"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "example": "src_001"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/enums/source_kind"
        },
        "fetched_at": {
          "type": "string",
          "format": "date-time"
        },
        "http_status": {
          "type": "integer",
          "nullable": true
        }
      }
    },
    "Evidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "deal_id",
        "source_id",
        "source_url",
        "claim",
        "quote",
        "evidence_type",
        "confidence",
        "freshness",
        "captured_at"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "example": "ev_001"
        },
        "deal_id": {
          "type": "string"
        },
        "source_id": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_title": {
          "type": "string",
          "nullable": true
        },
        "claim": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "evidence_type": {
          "$ref": "#/enums/evidence_type"
        },
        "confidence": {
          "$ref": "#/enums/confidence"
        },
        "freshness": {
          "$ref": "#/enums/freshness"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "AxisScore": {
      "type": "object",
      "required": [
        "axis",
        "score",
        "rationale",
        "evidence_ids"
      ],
      "properties": {
        "axis": {
          "$ref": "#/enums/screening_axis"
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "rationale": {
          "type": "string"
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ScreeningResult": {
      "type": "object",
      "required": [
        "deal_id",
        "axis_scores",
        "weakest_axis",
        "selected_counter_case_lens"
      ],
      "properties": {
        "deal_id": {
          "type": "string"
        },
        "axis_scores": {
          "type": "array",
          "items": {
            "$ref": "#/schemas/AxisScore"
          }
        },
        "weakest_axis": {
          "$ref": "#/enums/screening_axis"
        },
        "selected_counter_case_lens": {
          "$ref": "#/enums/screening_axis"
        },
        "overall_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "Memo": {
      "type": "object",
      "required": [
        "memo_id",
        "deal_id",
        "recommendation",
        "summary",
        "investment_thesis",
        "key_risks",
        "diligence_questions",
        "evidence_ids",
        "created_at"
      ],
      "properties": {
        "memo_id": {
          "type": "string",
          "example": "memo_001"
        },
        "deal_id": {
          "type": "string"
        },
        "recommendation": {
          "$ref": "#/enums/recommendation"
        },
        "summary": {
          "type": "string"
        },
        "investment_thesis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "key_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diligence_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "AdversarialObjection": {
      "type": "object",
      "required": [
        "objection_id",
        "title",
        "argument",
        "severity",
        "evidence_ids",
        "is_speculation"
      ],
      "properties": {
        "objection_id": {
          "type": "string",
          "example": "obj_001"
        },
        "title": {
          "type": "string"
        },
        "argument": {
          "type": "string"
        },
        "severity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "is_speculation": {
          "type": "boolean"
        },
        "speculation_label": {
          "type": "string",
          "nullable": true,
          "example": "Speculation: risk inferred from missing evidence, not a known fact."
        }
      }
    },
    "AdversaryReport": {
      "type": "object",
      "required": [
        "report_id",
        "deal_id",
        "memo_id",
        "counter_case_lens",
        "weakest_axis",
        "summary",
        "objections",
        "created_at"
      ],
      "properties": {
        "report_id": {
          "type": "string",
          "example": "adv_001"
        },
        "deal_id": {
          "type": "string"
        },
        "memo_id": {
          "type": "string"
        },
        "counter_case_lens": {
          "$ref": "#/enums/screening_axis"
        },
        "weakest_axis": {
          "$ref": "#/enums/screening_axis"
        },
        "summary": {
          "type": "string"
        },
        "objections": {
          "type": "array",
          "items": {
            "$ref": "#/schemas/AdversarialObjection"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "TruthGapCheckedObjection": {
      "type": "object",
      "required": [
        "objection_id",
        "badge",
        "hallucination_found",
        "evidence_relevance",
        "judge_notes"
      ],
      "properties": {
        "objection_id": {
          "type": "string"
        },
        "badge": {
          "$ref": "#/enums/objection_badge"
        },
        "hallucination_found": {
          "type": "boolean"
        },
        "evidence_relevance": {
          "type": "string",
          "enum": [
            "supports",
            "partially_supports",
            "does_not_support",
            "not_applicable_speculation"
          ]
        },
        "contradicted_by_evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "corrected_argument": {
          "type": "string",
          "nullable": true
        },
        "judge_notes": {
          "type": "string"
        }
      }
    },
    "TruthGapVerificationReport": {
      "type": "object",
      "required": [
        "verification_id",
        "deal_id",
        "adversary_report_id",
        "checked_objections",
        "created_at"
      ],
      "properties": {
        "verification_id": {
          "type": "string",
          "example": "ver_001"
        },
        "deal_id": {
          "type": "string"
        },
        "adversary_report_id": {
          "type": "string"
        },
        "checked_objections": {
          "type": "array",
          "items": {
            "$ref": "#/schemas/TruthGapCheckedObjection"
          }
        },
        "verified_count": {
          "type": "integer"
        },
        "unverified_count": {
          "type": "integer"
        },
        "speculation_count": {
          "type": "integer"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "OptionalVerdictBrief": {
      "type": "object",
      "required": [
        "brief_id",
        "deal_id",
        "memo_id",
        "verification_id",
        "decision_impact",
        "signal",
        "summary",
        "created_at"
      ],
      "properties": {
        "brief_id": {
          "type": "string",
          "example": "brief_001"
        },
        "deal_id": {
          "type": "string"
        },
        "memo_id": {
          "type": "string"
        },
        "verification_id": {
          "type": "string"
        },
        "decision_impact": {
          "$ref": "#/enums/decision_impact"
        },
        "signal": {
          "$ref": "#/enums/brief_signal"
        },
        "summary": {
          "type": "string"
        },
        "strongest_verified_objection_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "speculation_to_review": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "DecisionPacket": {
      "type": "object",
      "required": [
        "deal",
        "sources",
        "evidence",
        "screening",
        "memo",
        "adversary_report",
        "truth_gap_verification"
      ],
      "properties": {
        "deal": {
          "$ref": "#/schemas/Deal"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/schemas/Source"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/schemas/Evidence"
          }
        },
        "screening": {
          "$ref": "#/schemas/ScreeningResult"
        },
        "memo": {
          "$ref": "#/schemas/Memo"
        },
        "adversary_report": {
          "$ref": "#/schemas/AdversaryReport"
        },
        "truth_gap_verification": {
          "$ref": "#/schemas/TruthGapVerificationReport"
        },
        "verdict_brief": {
          "$ref": "#/schemas/OptionalVerdictBrief",
          "nullable": true
        }
      }
    }
  },
  "backend_api": {
    "base_path": "/api",
    "endpoints": [
      {
        "method": "POST",
        "path": "/deals",
        "description": "Create a deal from reviewer intake.",
        "request_schema": "#/schemas/DealIntake",
        "response_schema": "#/schemas/Deal"
      },
      {
        "method": "GET",
        "path": "/deals/{deal_id}",
        "description": "Fetch deal metadata and status.",
        "response_schema": "#/schemas/Deal"
      },
      {
        "method": "POST",
        "path": "/deals/{deal_id}/research",
        "description": "Start research, crawling, and evidence extraction.",
        "response_schema": "#/schemas/Job"
      },
      {
        "method": "POST",
        "path": "/deals/{deal_id}/screen",
        "description": "Start screening score generation.",
        "response_schema": "#/schemas/Job"
      },
      {
        "method": "POST",
        "path": "/deals/{deal_id}/memo",
        "description": "Start investment memo generation.",
        "response_schema": "#/schemas/Job"
      },
      {
        "method": "POST",
        "path": "/deals/{deal_id}/counter-case",
        "description": "Start devil's advocate and truth-gap verification stages.",
        "response_schema": "#/schemas/Job"
      },
      {
        "method": "POST",
        "path": "/deals/{deal_id}/verdict-brief",
        "description": "Optionally generate a non-authoritative reviewer brief from verified objections.",
        "response_schema": "#/schemas/Job"
      },
      {
        "method": "GET",
        "path": "/deals/{deal_id}/packet",
        "description": "Fetch the full reviewer decision packet.",
        "response_schema": "#/schemas/DecisionPacket"
      },
      {
        "method": "GET",
        "path": "/jobs/{job_id}",
        "description": "Poll async job status.",
        "response_schema": "#/schemas/Job"
      },
      {
        "method": "POST",
        "path": "/deals/{deal_id}/decision",
        "description": "Record the audit-logged human reviewer decision.",
        "request_schema": {
          "type": "object",
          "required": [
            "decision",
            "reviewer_id"
          ],
          "properties": {
            "decision": {
              "$ref": "#/enums/recommendation"
            },
            "reviewer_id": {
              "type": "string"
            },
            "notes": {
              "type": "string",
              "nullable": true
            }
          }
        },
        "response_schema": "#/schemas/Deal"
      }
    ]
  },
  "ai_service_api": {
    "base_path": "/v1/ai",
    "endpoints": [
      {
        "method": "POST",
        "path": "/research/plan",
        "owner": "ai_service",
        "description": "Create search queries and crawl targets from deal intake."
      },
      {
        "method": "POST",
        "path": "/evidence/extract",
        "owner": "ai_service",
        "description": "Extract Memory evidence records from crawled text."
      },
      {
        "method": "POST",
        "path": "/screen/score",
        "owner": "ai_service",
        "description": "Score the deal across venture screening axes.",
        "response_schema": "#/schemas/ScreeningResult"
      },
      {
        "method": "POST",
        "path": "/memo/write",
        "owner": "ai_service",
        "description": "Write the investment memo from evidence and scores.",
        "response_schema": "#/schemas/Memo"
      },
      {
        "method": "POST",
        "path": "/adversary/write",
        "owner": "ai_service",
        "description": "Write the strongest bounded counter-case against investing.",
        "response_schema": "#/schemas/AdversaryReport"
      },
      {
        "method": "POST",
        "path": "/truth-gap/verify",
        "owner": "ai_service",
        "description": "Reuse the truth-gap Judge to badge adversarial objections as verified, unverified, or speculation.",
        "response_schema": "#/schemas/TruthGapVerificationReport"
      },
      {
        "method": "POST",
        "path": "/verdict/brief",
        "owner": "ai_service",
        "description": "Optionally summarize verified objections for human readability without making the final decision.",
        "response_schema": "#/schemas/OptionalVerdictBrief"
      }
    ]
  },
  "event_stream": {
    "transport": "server_sent_events_or_websocket",
    "event_types": [
      "job_started",
      "source_found",
      "evidence_added",
      "screening_ready",
      "memo_ready",
      "counter_case_ready",
      "verification_ready",
      "verdict_brief_ready",
      "packet_ready",
      "job_failed"
    ]
  },
  "deterministic_counter_case_lens_selection": {
    "rule": "Select the counter_case_lens from the weakest screening axis. If multiple axes tie, use the tie_breaker_order.",
    "tie_breaker_order": [
      "risk",
      "founder",
      "traction",
      "market",
      "product",
      "business_model",
      "fundraising"
    ]
  }
}
